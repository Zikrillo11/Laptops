@model Laptops.Shared.DTOs.Laptops.LoginDto

<!DOCTYPE html>
<html lang="en">

<head>

    <meta charset="UTF-8">

    <meta name="viewport"
          content="width=device-width, initial-scale=1.0">

    <title>Laptops Admin</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css"
          rel="stylesheet">

    <style>
          
            * {
                margin: 0;
                padding: 0;
                box-sizing: border-box;
                font-family: 'Segoe UI',sans-serif;
            }

            body {
                min-height: 100vh;
                display: flex;
                justify-content: center;
                align-items: center;
                background: #050816;
                overflow: hidden;
                position: relative;
            }

            .blob1 {
                position: absolute;
                width: 500px;
                height: 500px;
                background: #7c3aed;
                border-radius: 50%;
                left: -150px;
                top: -150px;
                filter: blur(150px);
                animation: float1 8s infinite alternate;
            }

            .blob2 {
                position: absolute;
                width: 500px;
                height: 500px;
                background: #2563eb;
                border-radius: 50%;
                right: -150px;
                bottom: -150px;
                filter: blur(150px);
                animation: float2 8s infinite alternate;
            }

              
               
            .login-card {
                width: 430px;
                padding: 45px;
                border-radius: 35px;
                background: rgba(255,255,255,.08);
                backdrop-filter: blur(25px);
                border: 1px solid rgba(255,255,255,.12);
                box-shadow: 0 0 30px rgba(124,58,237,.4), 0 0 60px rgba(37,99,235,.2);
                z-index: 10;
                position: relative;
            }

            .avatar {
                width: 120px;
                height: 120px;
                border-radius: 50%;
                margin: auto;
                margin-bottom: 20px;
                display: flex;
                justify-content: center;
                align-items: center;
                background: rgba(255,255,255,.08);
                border: 1px solid rgba(255,255,255,.15);
            }

                .avatar i {
                    color: white;
                    font-size: 65px;
                }

            h1 {
                text-align: center;
                color: white;
                margin-bottom: 5px;
                font-size: 34px;
            }

            .subtitle {
                text-align: center;
                color: #cbd5e1;
                margin-bottom: 35px;
            }

            .input-box {
                margin-bottom: 25px;
                border-bottom: 1px solid rgba(255,255,255,.25);
                display: flex;
                align-items: center;
            }

                .input-box i {
                    color: white;
                    margin-right: 12px;
                }

                .input-box input {
                    width: 100%;
                    background: none;
                    border: none;
                    outline: none;
                    color: white;
                    padding: 15px 0;
                    font-size: 15px;
                }

                    .input-box input::placeholder {
                        color: #cbd5e1;
                    }

            .options {
                display: flex;
                justify-content: space-between;
                margin-bottom: 25px;
                color: white;
                font-size: 14px;
            }

                .options a {
                    color: #93c5fd;
                    text-decoration: none;
                }

            .login-btn {
                width: 100%;
                height: 55px;
                border: none;
                border-radius: 15px;
                background: linear-gradient( 90deg, #ec4899, #7c3aed, #2563eb );
                color: white;
                font-size: 17px;
                font-weight: 700;
                letter-spacing: 2px;
                cursor: pointer;
                transition: .3s;
            }

                .login-btn:hover {
                    transform: translateY(-3px);
                    box-shadow: 0 10px 30px rgba(124,58,237,.5);
                }

            .error {
                background: rgba(239,68,68,.15);
                border: 1px solid rgba(239,68,68,.3);
                color: white;
                padding: 12px;
                border-radius: 10px;
                margin-bottom: 20px;
                text-align: center;
            }

            .footer {
                text-align: center;
                margin-top: 25px;
                color: #94a3b8;
                font-size: 12px;
            }

    </style>

</head>

<body>

    <div class="blob1"></div>
    <div class="blob2"></div>

    <div class="login-card">

        <div class="avatar">
            <i class="bi bi-person-fill"></i>
        </div>

        <h1>Welcome Back</h1>

        <div class="subtitle">
            Sign in to continue to Laptops Admin
        </div>

        @if (ViewBag.Error != null)
        {
            <div class="error">
                @ViewBag.Error
            </div>
        }

        <form method="post">

            <div class="input-box">

                <i class="bi bi-envelope-fill"></i>

                <input asp-for="Username"
                       placeholder="Email ID">

            </div>

            <div class="input-box">

                <i class="bi bi-lock-fill"></i>

                <input asp-for="Password"
                       type="password"
                       placeholder="Password">

            </div>

            <div class="options">

                <label>
                    <input type="checkbox">
                    Remember me
                </label>

                <a href="#">
                    Forgot Password?
                </a>
                    
            </div> 
               
            <button type="submit"
                    class="login-btn">
                LOGIN
            </button>

        </form>

        <div class="footer">
            © 2026 Laptops Admin Panel
        </div>

    </div>

</body>

</html>