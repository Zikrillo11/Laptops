@model IEnumerable<Laptops.Shared.DTOs.Laptops.LaptopForResultDto>

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
      rel="stylesheet">

<style>

    body {
        background: #f5f7fb;
    }

    .hero { 
        background: linear-gradient(135deg,#2563eb,#1e40af);
        color: white;
        padding: 80px 0;
        text-align: center;
        margin-bottom: 50px;
    }

    .laptop-card {
        border: none;
        border-radius: 20px;
        overflow: hidden;
        transition: 0.3s;
        box-shadow: 0 5px 20px rgba(0,0,0,.08);
    }

        .laptop-card:hover {
            transform: translateY(-8px);
        }

    .laptop-image {
        height: 220px;
        object-fit: cover;
    }

    .price {
        font-size: 24px;
        font-weight: bold;
        color: #2563eb;
    }

</style>

<div class="hero">

    <div class="container">

        <h1 class="display-4 fw-bold">
            💻 Laptop Store
        </h1>

        <p class="lead">
            Best laptops for work, gaming and study
        </p>

    </div>

</div>

<div class="container">

    <div class="row">

        @foreach (var item in Model)
        {
            <div class="col-lg-4 col-md-6 mb-4">

                <div class="card laptop-card">

                    <img src="https://images.unsplash.com/photo-1496181133206-80ce9b88a853?w=800"
                         class="laptop-image">

                    <div class="card-body">

                        <h4>@item.Name</h4>

                        <p class="text-muted">
                            @item.Brand
                        </p>

                        <div class="price mb-3">
                            $@item.Price
                        </div>

                        <a href="#"
                           class="btn btn-primary w-100">
                            View Details
                        </a>

                    </div>

                </div>

            </div>
        }

    </div>

</div>